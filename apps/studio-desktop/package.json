{
  "name": "@odiumflix/studio-desktop",
  "version": "0.3.0-alpha.3",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "tsc && electron-builder --win nsis"
  },
  "dependencies": {
    "ffmpeg-static": "latest",
    "ffprobe-static": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "typescript": "7.0.2"
  },
  "build": {
    "appId": "com.odiumstudio.odiumflix.studio",
    "productName": "OdiumFlix Studio",
    "asar": true,
    "asarUnpack": ["node_modules/ffmpeg-static/**/*", "node_modules/ffprobe-static/**/*"],
    "files": ["dist/**/*", "package.json", "node_modules/**/*"],
    "directories": {"output": "release"},
    "win": {"target": ["nsis"], "artifactName": "OdiumFlix-Studio-${version}-${arch}.${ext}"},
    "extraResources": [
      {"from": "../studio/dist", "to": "studio"},
      {"from": "resources", "to": "worker", "filter": ["**/*"]},
      {"from": "node_modules/ffmpeg-static/ffmpeg.exe", "to": "media-tools/ffmpeg.exe"},
      {"from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe", "to": "media-tools/ffprobe.exe"}
    ]
  }
}
